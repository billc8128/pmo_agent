# Anthropic-compatible LLM backend (we use 火山方舟 Coding Plan)
ANTHROPIC_AUTH_TOKEN=ark-xxxxxxxx
ANTHROPIC_BASE_URL=https://ark.cn-beijing.volces.com/api/coding
ANTHROPIC_MODEL=ark-code-latest

# Feishu (lark) self-built app
FEISHU_APP_ID=cli_xxxxxxxx
FEISHU_APP_SECRET=xxxxxxxx
FEISHU_ENCRYPT_KEY=optional-but-recommended
FEISHU_VERIFICATION_TOKEN=optional

# Supabase
# ANON_KEY is used for RLS-respecting public reads.
# SERVICE_ROLE_KEY is server-only and required for Feishu identity lookups,
# bot_workspace bootstrap, bot_actions idempotency/audit rows, and write tools.
SUPABASE_URL=https://xecnsibhijdlwqulkxor.supabase.co
SUPABASE_ANON_KEY=sb_publishable_xxxxxxxx
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxx

# Misc
WEB_BASE_URL=https://pmo-agent-sigma.vercel.app
LOG_LEVEL=INFO
